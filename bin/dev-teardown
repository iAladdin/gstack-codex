#!/usr/bin/env bash
# Remove local dev skill symlinks. Restores the normal gstack-codex install path.
set -e

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SKILLS_DIR="$REPO_ROOT/.codex/skills"

if [ ! -d "$SKILLS_DIR" ]; then
  echo "Nothing to tear down — .codex/skills/ doesn't exist."
  exit 0
fi

# Remove individual skill symlinks
removed=()
for link in "$SKILLS_DIR"/*/; do
  name="$(basename "$link")"
  [ "$name" = "gstack-codex" ] && continue
  if [ -L "${link%/}" ]; then
    rm "${link%/}"
    removed+=("$name")
  fi
done

# Remove the gstack-codex symlink
if [ -L "$SKILLS_DIR/gstack-codex" ]; then
  rm "$SKILLS_DIR/gstack-codex"
  removed+=("gstack-codex")
fi

# Clean up empty dirs
rmdir "$SKILLS_DIR" 2>/dev/null || true
rmdir "$REPO_ROOT/.codex" 2>/dev/null || true

if [ ${#removed[@]} -gt 0 ]; then
  echo "Removed: ${removed[*]}"
else
  echo "No symlinks found."
fi
echo "Dev mode deactivated."
